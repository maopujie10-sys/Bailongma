import { pushMessage } from '../../queue.js'
import { callCapability } from '../../providers/registry.js'
import { isDailyLimitReached } from '../../quota.js'
import { getTTSCredentials, getTTSConfig, getSeedanceConfig } from '../../config.js'
import { streamTTS, TTS_VOICES, validateTTSConfig } from '../../voice/tts-providers.js'
import { paths } from '../../paths.js'
import { SANDBOX_ROOT } from '../sandbox.js'
import { getCountryCode } from '../../geo-weather.js'

const IS_WIN = process.platform === 'win32'

// speakпјҡе°Ҷж–Үеӯ—иҪ¬дёәиҜӯйҹіпјҢдҝқеӯҳдёәйҹійў‘ж–Үд»¶
function resolveProviderVoiceId(provider, requestedVoiceId, configuredVoiceId) {
  const voices = TTS_VOICES[provider] || []
  if (!voices.length) return requestedVoiceId || configuredVoiceId || undefined

  const validIds = new Set(voices.map(v => v.id))
  if (requestedVoiceId && validIds.has(requestedVoiceId)) return requestedVoiceId
  if (requestedVoiceId) {
    console.warn(`[speak] Ignoring voice_id "${requestedVoiceId}" because it is not valid for TTS provider "${provider}"`)
  }

  if (configuredVoiceId && validIds.has(configuredVoiceId)) return configuredVoiceId
  if (configuredVoiceId) {
    console.warn(`[speak] Ignoring configured voice "${configuredVoiceId}" because it is not valid for TTS provider "${provider}"`)
  }

  return voices[0]?.id
}

// жң—иҜ»ж–Үжң¬й•ҝеәҰдёҠйҷҗпјҲдёҺ schema жҸҸиҝ°еҜ№йҪҗдёәеҗҢдёҖеёёйҮҸпјӣеүҘжҺ?markdown еҗҺеҶҚи®Ўпјү
const SPEAK_MAX_CHARS = 1000

// жҠҠжөҒзј“еҶІжҲҗе®Ңж•ҙйҹійў?bufferпјӣз©әйҹійў‘и§ҶдёәеӨұиҙҘпјҲеҫҲеӨ?provider еңЁйҹіиүІж— жқғйҷҗ/еҸӮж•°й”ҷж—¶иҝ”еӣһз©әжөҒпј?async function collectAudioStream(nodeStream) {
  const chunks = []
  for await (const chunk of nodeStream) {
    chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(chunk))
  }
  return Buffer.concat(chunks)
}

// еҸҜйҮҚиҜ•зҡ„зһ¬ж—¶й”ҷиҜҜпјҡзҪ‘з»ңжҠ–еҠ?/ йҷҗжөҒ / 5xxгҖӮеҮӯиҜҒй”ҷгҖҒеҸӮж•°й”ҷдёҚеңЁжӯӨеҲ—пјҲйҮҚиҜ•ж— ж„Ҹд№үпјүгҖ?function isTransientTTSError(err) {
  const m = String(err?.message || '')
  return /\b(429|500|502|503|504)\b/.test(m)
    || /timeout|ETIMEDOUT|ECONNRESET|ECONNREFUSED|ENOTFOUND|EAI_AGAIN|socket hang up|fetch failed|network|aborted/i.test(m)
}

// еҗҲжҲҗпјҡзһ¬ж—¶еӨұиҙҘиҮӘеҠЁйҮҚиҜ•дёҖж¬Ўпјӣе…¶дҪҷзӣҙжҺҘжҠӣз»ҷдёҠеұӮеҪ’дёҖеҢ?async function synthSpeechBuffer({ text, provider, voiceId, creds }) {
  let lastErr
  for (let attempt = 0; attempt < 2; attempt++) {
    try {
      const nodeStream = await streamTTS({ text, provider, voiceId, keys: creds })
      const buffer = await collectAudioStream(nodeStream)
      if (!buffer.length) throw new Error('TTS иҝ”еӣһз©әйҹійў‘пјҲйҹіиүІеҸҜиғҪжңӘеңЁиҙҰеҸ·ејҖйҖҡпјҢжҲ–еҸӮж•°дёҚиў«ж”ҜжҢҒпјү')
      return buffer
    } catch (err) {
      lastErr = err
      if (err.name === 'AbortError') throw err
      if (attempt === 0 && isTransientTTSError(err)) {
        console.warn(`[speak] еҗҲжҲҗеӨұиҙҘ(зһ¬ж—¶пјҢйҮҚиҜ•дёҖж¬?: ${err.message}`)
        await new Promise(r => setTimeout(r, 600))
        continue
      }
      throw err
    }
  }
  throw lastErr
}

// жҠҠеҗ„е®?SDK зҡ„иЈёй”ҷиҜҜеҪ’дёҖжҲ?иҜҘеҺ»е“Әж”№д»Җд№?зҡ„еҸҜжү§иЎҢдёӯж–ҮжҸҗзӨәпјҢдҫӣжЁЎеһӢиҪ¬иҝ°з»ҷз”ЁжҲ?function normalizeTTSError(err, provider) {
  const msg = String(err?.message || 'жңӘзҹҘй”ҷиҜҜ').slice(0, 200)
  if (/resource ID is mismatched|55000000/i.test(msg)) {
    return `иҜӯйҹіеҗҲжҲҗеӨұиҙҘпјҡиұҶеҢ…йҹіиүІдёҺ Resource ID дёҚеҢ№й…ҚгҖ?.0 йҹіиүІпј?_uranus_bigttsпјүйңҖз”?seed-tts-2.0пјҢж—§ moon/BV йҹіиүІйңҖ seed-tts-1.0гҖӮиҜ·еҺ»иҜӯйҹіи®ҫзҪ®еҲҮжҚўйҹіиүІпјҢжҲ–жё…з©?ж”№жӯЈ Resource IDгҖӮпјҲ${msg}пјү`
  }
  if (/\b(401|403)\b/.test(msg) || /unauthor|invalid.*(key|token)|api[ _-]?key/i.test(msg)) {
    return `иҜӯйҹіеҗҲжҲҗеӨұиҙҘпјҡеҪ“еүҚжңҚеҠЎе•Ҷпј?{provider}пјүзҡ„еҮӯиҜҒеҸҜиғҪж— ж•ҲжҲ–е·ІиҝҮжңҹгҖӮиҜ·еҺ»иҜӯйҹіи®ҫзҪ®йҮҚж–°еЎ«еҶҷеҗҺеҶҚиҜ•гҖӮпјҲ${msg}пјү`
  }
  if (/\b429\b|rate.?limit|quota|й…Қйўқ|дҪҷйўқ|insufficient/i.test(msg)) {
    return `иҜӯйҹіеҗҲжҲҗеӨұиҙҘпјҡжңҚеҠЎе•Ҷпј?{provider}пјүи§ҰеҸ‘йҷҗжөҒжҲ–й…Қйўқ/дҪҷйўқдёҚи¶ігҖӮиҜ·зЁҚеҗҺеҶҚиҜ•жҲ–жЈҖжҹҘиҙҰжҲ·гҖӮпјҲ${msg}пјү`
  }
  if (isTransientTTSError(err)) {
    return `иҜӯйҹіеҗҲжҲҗеӨұиҙҘпјҡзҪ‘з»ңжҲ–жңҚеҠЎжҡӮж—¶дёҚеҸҜз”ЁпјҲе·ІиҮӘеҠЁйҮҚиҜ•дёҖж¬ЎпјүгҖӮиҜ·зЁҚеҗҺеҶҚиҜ•гҖӮпјҲ${msg}пјү`
  }
  return `иҜӯйҹіеҗҲжҲҗеӨұиҙҘпј?{msg}`
}

export async function execSpeak(args) {
  const rawText = args.text || args.content || args.words || args.speech
  const { filename } = args
  console.log(`[speak] args:`, JSON.stringify(args))
  if (!rawText) return 'й”ҷиҜҜпјҡжңӘжҸҗдҫӣиҰҒжң—иҜ»зҡ„ж–Үеӯ—'
  if (isDailyLimitReached('tts')) return 'й”ҷиҜҜпјҡд»Ҡж—?TTS й…Қйўқе·Із”Ёе®?

  // дёҺжөҒеј?/tts/stream е…ҘеҸЈеҜ№йҪҗпјҡе…Ҳеү?markdownпјҢйҒҝе…ҚжҠҠ * # ` зӯүз¬ҰеҸ·еҝөжҲ?жҳҹеҸ·""дә•еҸ·"
  const text = stripMarkdownForSpeech(rawText)
  if (!text) return 'й”ҷиҜҜпјҡеҺ»жҺүз¬ҰеҸ·еҗҺжІЎжңүеҸҜжң—иҜ»зҡ„ж–Үеӯ—'
  if (text.length > SPEAK_MAX_CHARS) return `й”ҷиҜҜпјҡж–Үеӯ—иҝҮй•ҝпјҲ${text.length} еӯ—пјүпјҢиҜ·жҺ§еҲ¶ең?${SPEAK_MAX_CHARS} еӯ—д»ҘеҶ…`

  const creds = getTTSCredentials()

  // еҗҲжҲҗеүҚйў„жЈҖпјҡеҪ“еүҚжңҚеҠЎе•ҶеҮӯиҜҒжІЎй…ҚйҪҗе°ұзӣҙжҺҘиҝ”еӣһз»“жһ„еҢ–еј•еҜјпјҢдёҚеҶІеҲ?API жүҚиЈёжҠҘй”ҷгҖ?  const check = validateTTSConfig(creds)
  if (!check.ok) return `иҜӯйҹіеҗҲжҲҗиҝҳдёҚиғҪз”Ёпј?{check.guide}`

  const requestedVoiceId = args.voice_id || args.voice
  const voiceId = resolveProviderVoiceId(creds.provider, requestedVoiceId, creds.voiceId)

  let buffer
  try {
    buffer = await synthSpeechBuffer({ text, provider: creds.provider, voiceId, creds })
  } catch (err) {
    if (err.name === 'AbortError') throw err
    console.warn(`[speak] еҗҲжҲҗеӨұиҙҘ: ${err.message}`)
    return normalizeTTSError(err, creds.provider)
  }

  const ts = nowTimestamp().replace(/[:.+]/g, '-').slice(0, 19)
  const fname = filename ? filename.replace(/[^a-zA-Z0-9_дёҖ-йҫ?]/g, '') + '.mp3' : `speech_${ts}.mp3`
  const resolved = path.resolve(SANDBOX_ROOT, 'audio', fname)
  fs.mkdirSync(path.dirname(resolved), { recursive: true })
  fs.writeFileSync(resolved, buffer)

  const relPath = `audio/${fname}`
  emitEvent('audio_created', { path: relPath, text: text.slice(0, 60), autoPlay: true })
  console.log(`[speak] е·Із”ҹжҲ? ${relPath}`)
  return `иҜӯйҹіе·Із”ҹжҲҗпјҡ${relPath}`
}

// markdown вҶ?жң—иҜ»з”ЁзәҜж–Үжң¬пјҡTTS еј•ж“ҺдјҡжҠҠ * # ` зӯүз¬ҰеҸ·зӣҙжҺҘеҝөеҮәжқҘпј?жҳҹжҳҹ"пјүпјҢ
// жүҖжңүиҝӣе…ҘеҗҲжҲҗзҡ„ж–Үжң¬йғҪиҰҒе…ҲиҝҮиҝҷйҮҢвҖ”вҖ?tts/stream е…ҘеҸЈз»ҹдёҖи°ғз”ЁпјҢжҳҜеүҘзҰ»зҡ„еҚ•дёҖжқғеЁҒ
export function stripMarkdownForSpeech(text) {
  return String(text || '').trim()
    .replace(/^[ \t]*([-*+]|\d+[.гҖҒ])\s+/gm, '')
    .replace(/\*\*\*(.+?)\*\*\*/g, '$1')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/`{1,3}(.+?)`{1,3}/g, '$1')
    .replace(/#{1,6}\s+/g, '')
    .replace(/!\[[^\]]*\]\([^\)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^\)]+\)/g, '$1')
    .replace(/\*\*/g, '') // еҠ зІ—и®°еҸ·иў«жөҒејҸеҲҮеҸҘеҲҮжҲҗдёӨеҚҠж—¶ж®Ӣз•ҷзҡ„еҚҠжҲ?    .replace(/\n+/g, ' ')
    .trim()
}

// иҜӯйҹіж¶ҲжҒҜиҮӘеҠЁеӣһеӨҚ TTSпјҡжЈҖжөӢеҲ°з”ЁжҲ·з”ЁиҜӯйҹіиҫ“е…Ҙж—¶пјҢйҖҡзҹҘеүҚз«Ҝж’ӯж”ҫиҜӯйҹі
// з”?index.js и°ғз”ЁпјҢеүҚз«Ҝж”¶еҲ?tts_reply дәӢд»¶еҗҺи°ғз”?/tts/stream е®ҢжҲҗе®һйҷ…еҗҲжҲҗ
export function autoSpeakForVoiceReply(text) {
  if (!text) return
  const plain = stripMarkdownForSpeech(text)
  if (!plain) return
  // зәҜиЎЁжғ?/ ж ҮзӮ№пјҲжІЎжңүд»»дҪ•еҸҜиҜ»ж–Үеӯ—пјүдёҚеҗҲжҲҗиҜӯйҹіпјҡж’ӯж”ҫзЎ®и®ӨзҺ°еңЁз”ЁеҚ•дё?emoji д»Јжӣҝпј?  // иҜӯйҹіжЁЎејҸдёӢдёҚиҜҘжҠҠе®ғеҝөеҮәжқҘпјҲ\p{L}=еӯ—жҜҚеҗ«жұүеӯ—пјҢ\p{N}=ж•°еӯ—пјүгҖ?  if (!/[\p{L}\p{N}]/u.test(plain)) return
  emitEvent('tts_reply', { text: plain })
}

// generate_lyricsпјҡз”ҹжҲҗжӯҢиҜ?export async function execGenerateLyrics({ prompt, mode }) {
  if (!prompt) return 'й”ҷиҜҜпјҡжңӘжҸҗдҫӣеҲӣдҪңж–№еҗ‘'
  if (isDailyLimitReached('lyrics')) return 'й”ҷиҜҜпјҡд»Ҡж—ҘжӯҢиҜҚз”ҹжҲҗй…Қйўқе·Із”Ёе®Ң'

  const result = await callCapability('lyrics', { prompt, mode })

  // иҮӘеҠЁдҝқеӯҳжӯҢиҜҚеҲ?sandbox
  const ts = nowTimestamp().replace(/[:.+]/g, '-').slice(0, 19)
  const fname = `lyrics_${ts}.txt`
  const content = `# ${result.title}\nйЈҺж јпј?{result.style}\n\n${result.lyrics}`
  const resolved = path.resolve(SANDBOX_ROOT, 'lyrics', fname)
  fs.mkdirSync(path.dirname(resolved), { recursive: true })
  fs.writeFileSync(resolved, content, 'utf-8')

  emitEvent('lyrics_created', { path: `lyrics/${fname}`, title: result.title })
  return `жӯҢиҜҚе·Із”ҹжҲҗе№¶дҝқеӯҳиҮ?lyrics/${fname}\n\nж Үйўҳпј?{result.title}\nйЈҺж јпј?{result.style}\n\n${result.lyrics}`
}

// generate_musicпјҡз”ҹжҲҗйҹід№?export async function execGenerateMusic({ prompt, lyrics, instrumental }) {
  if (!prompt) return 'й”ҷиҜҜпјҡжңӘжҸҗдҫӣйҹід№җжҸҸиҝ°'
  if (isDailyLimitReached('music')) return 'й”ҷиҜҜпјҡд»Ҡж—Ҙйҹід№җз”ҹжҲҗй…Қйўқе·Із”Ёе®Ң'

  const result = await callCapability('music', { prompt, lyrics, instrumental })

  const ts = nowTimestamp().replace(/[:.+]/g, '-').slice(0, 19)
  const fname = `music_${ts}.mp3`
  const resolved = path.resolve(SANDBOX_ROOT, 'music', fname)
  fs.mkdirSync(path.dirname(resolved), { recursive: true })
  fs.writeFileSync(resolved, result.buffer)

  const relPath = `music/${fname}`
  emitEvent('music_created', { path: relPath, prompt: prompt.slice(0, 60) })
  console.log(`[music] е·Із”ҹжҲ? ${relPath}`)
  return `йҹід№җе·Із”ҹжҲҗпјҡ${relPath}пјҲж—¶й•ҝзәҰ ${result.duration ?? '?'} з§’пјү`
}

// generate_imageпјҡз”ҹжҲҗеӣҫзү?export async function execGenerateImage({ prompt, aspect_ratio = '1:1', n = 1 }) {
  if (!prompt) return 'й”ҷиҜҜпјҡжңӘжҸҗдҫӣеӣҫзүҮжҸҸиҝ°'
  if (isDailyLimitReached('image')) return 'й”ҷиҜҜпјҡд»Ҡж—ҘеӣҫзүҮз”ҹжҲҗй…Қйўқе·Із”Ёе®Ңпј?0 ж¬?еӨ©пјү'
  const validRatios = new Set(['1:1', '16:9', '4:3', '3:4', '9:16'])
  const ratio = validRatios.has(aspect_ratio) ? aspect_ratio : '1:1'
  const count = Math.min(Math.max(Math.floor(n) || 1, 1), 4)

  const result = await callCapability('image', { prompt, aspect_ratio: ratio, n: count })

  emitEvent('image_created', { urls: result.urls, prompt: prompt.slice(0, 60) })
  console.log(`[image] е·Із”ҹжҲ?${result.urls.length} еј еӣҫзүҮ`)
  return `еӣҫзүҮе·Із”ҹжҲҗпјҲ${result.urls.length} еј пјүпјҡ\n${result.urls.join('\n')}`
}

export function execMediaMode(args = {}) {
  const mode = String(args.mode || args.kind || '').trim()
  const action = String(args.action || 'show').trim()
  if (!['video', 'camera', 'image', 'music'].includes(mode)) {
    return JSON.stringify({ ok: false, tool: 'media_mode', error: 'mode must be video, camera, image, or music' })
  }
  if (!['show', 'hide', 'close', 'play', 'pause', 'seek', 'set_volume', 'update'].includes(action)) {
    return JSON.stringify({ ok: false, tool: 'media_mode', error: 'unsupported action' })
  }

  // и§Ҷйў‘е№іеҸ°йў„жЈҖпјҡCN зҪ‘з»ңдё?YouTube и§Ҷйў‘з»Ҹеёёж— жі• iframe еөҢе…Ҙж’ӯж”ҫпјҲembeddable=false / ең°еҢәйҷҗеҲ¶пјүпјҢ
  // иҝҷжҳҜ"и§Ҷйў‘ж— жі•ж’ӯж”ҫ/жӯӨи§Ҷйў‘дёҚиғҪи§Ӯзң?зҡ„дё»еӣ гҖӮCN з”ЁжҲ·дј?YouTube й“ҫжҺҘж—¶жҢЎеӣһпјҢеј•еҜјж”№з”Ё B з«?BV йҮҚж’ӯ
  // пјҲB з«ҷзЁҝд»¶еҮ д№ҺйғҪеҸҜеөҢе…ҘгҖҒеӣҪеҶ…д№ҹеҝ«пјүгҖӮcountry жңӘзҹҘж—¶жҢү CN дҝқе®ҲеӨ„зҗҶгҖӮж‘„еғҸеӨҙжЁЎејҸдёҚжӢҰгҖ?  if (mode === 'video' && action === 'show' && args.camera !== true) {
    const u = String(args.url || args.src || '')
    if (/youtube\.com|youtu\.be/i.test(u)) {
      const cc = getCountryCode()
      if (cc === 'CN' || cc === null) {
        emitEvent('action', { tool: 'media_mode', summary: 'YouTube й“ҫжҺҘе·ІжҢЎеӣһпјҲCNвҶ’ж”№з”?B з«ҷпјү', detail: u.slice(0, 60) })
        return JSON.stringify({
          ok: false, tool: 'media_mode', error: 'youtube_not_embeddable_cn',
          guide: 'еҪ“еүҚзҪ‘з»ңеңЁдёӯеӣҪеӨ§йҷҶпјҢYouTube и§Ҷйў‘з»Ҹеёёж— жі•еөҢе…Ҙж’ӯж”ҫпјҲз”ЁжҲ·дјҡзңӢеҲ°"жӯӨи§Ҷйў‘дёҚиғҪи§Ӯзң?пјүгҖӮдёҚиҰҒз”Ё YouTube й“ҫжҺҘгҖӮиҜ·ж”№з”Ё web_search ең?Bilibili дёҠжҗңеҗҢдёҖдё»йўҳзҡ„и§Ҷйў‘пјҢжӢҝеҲ°еҪўеҰӮ https://www.bilibili.com/video/BVxxxxxxxxxx зҡ„й“ҫжҺҘеҗҺпјҢеҶҚз”?media_mode(mode="video") йҮҚж–°ж’ӯж”ҫгҖӮдјҳе…ҲйҖүе®ҳж–?й«ҳж’ӯж”ҫйҮҸзҡ„зЁҝд»¶пјҢзЎ®и®ӨжҳҜеҸҜжӯЈеёёж’ӯж”ҫзҡ„е®Ңж•ҙи§Ҷйў‘иҖҢдёҚжҳҜеҗҲйӣ?зӣҙж’ӯеӣһж”ҫгҖ?,
        })
      }
    }
  }

  const payload = {
    mode,
    action,
    url: typeof args.url === 'string' ? args.url : undefined,
    src: typeof args.src === 'string' ? args.src : undefined,
    title: typeof args.title === 'string' ? args.title : undefined,
    artist: typeof args.artist === 'string' ? args.artist : undefined,
    lrc: typeof args.lrc === 'string' ? args.lrc : undefined,
    cover: typeof args.cover === 'string' ? args.cover : undefined,
    alt: typeof args.alt === 'string' ? args.alt : undefined,
    autoplay: typeof args.autoplay === 'boolean' ? args.autoplay : (mode === 'music' ? true : undefined),
    muted: typeof args.muted === 'boolean' ? args.muted : undefined,
    camera: mode === 'camera' || args.camera === true,
  }

  if (Number.isFinite(Number(args.volume))) {
    payload.volume = Math.max(0, Math.min(1, Number(args.volume)))
  }
  if (Number.isFinite(Number(args.currentTime ?? args.time ?? args.seek))) {
    payload.currentTime = Math.max(0, Number(args.currentTime ?? args.time ?? args.seek))
  }

  emitEvent('media_mode', payload)
  emitEvent('action', { tool: 'media_mode', summary: `${mode}:${action}`, detail: payload.title || payload.url || '' })
  return JSON.stringify({ ok: true, tool: 'media_mode', ...payload })
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// AI и§Ҷйў‘з”ҹжҲҗпјҲSeedance 2.0 / зҒ«еұұж–№иҲҹ Arkпј?//
// ејӮжӯҘд»»еҠЎејҸпјҡеҲӣе»әд»»еҠЎ вҶ?еҗҺеҸ°иҪ®иҜў вҶ?дёӢиҪҪ mp4 еҲ?sandbox вҶ?жҺЁз»ҷеүҚз«ҜйқўжқҝиҮӘеҠЁж’ӯж”ҫгҖ?// и®ҫи®ЎиҰҒзӮ№пј?//   1) жңӘй…ҚзҪ?key вҶ?иҝ”еӣһз»“жһ„еҢ–еј•еҜјж–ҮжЎҲпјҲдёҚеҒҡзЎ¬жӢҰжҲӘпјҢз”ұжЁЎеһӢиҪ¬иҝ°жҢҮеј•з”ЁжҲ·зІҳиҙ?keyпјүгҖ?//   2) еҲӣе»әд»»еҠЎеҗҢжӯҘ awaitпјҢеӨұиҙҘз«ӢеҲ»еӣһдј з»ҷжЁЎеһӢпјҲе…ёеһӢпјҡmodel ID дёҚеҜ№ / дҪҷйўқдёҚи¶іпјүгҖ?//   3) иҪ®иҜўеңЁеҗҺеҸ°иҝӣиЎҢпјҲдёҚйҳ»еЎһеҪ“еү?turnпјүпјҢе…ЁзЁӢеҸ?emit йқўжқҝдәӢд»¶пјҢе®ҢжҲ?еӨұиҙҘйғҪдҪ“зҺ°еңЁйқўжқҝдёҠгҖ?// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

const SEEDANCE_POLL_INTERVAL_MS = 5000
const SEEDANCE_MAX_POLL_MS = 8 * 60 * 1000   // 8 еҲҶй’ҹе…ңеә•и¶…ж—¶
const SEEDANCE_VIDEO_DIR = path.resolve(SANDBOX_ROOT, 'videos')

const SEEDANCE_VIDEO_KEEP = 20                          // sandbox/videos еҸӘдҝқз•ҷжңҖиҝ?N жқ?const SEEDANCE_PENDING_FILE = path.join(paths.userDir, 'aivideo-pending.json')
const SEEDANCE_PENDING_TTL_MS = 48 * 60 * 60 * 1000     // зҒ«еұұд»»еҠЎзә?48h еҶ…еҸҜжҹҘпјҢиҝҮжңҹдёҚеҶҚжҒўеӨҚ
const SEEDANCE_HISTORY_FILE = path.join(paths.userDir, 'aivideo-history.json')  // е·Іе®ҢжҲҗи§Ҷйў‘еҺҶеҸІпјҲйқўжқҝйҮҚејҖ/йҮҚеҗҜеҗҺйҮҚе»әйҳҹеҲ—пјү

function newVideoJobId() {
  return `vid_${Date.now().toString(36)}${Math.random().toString(36).slice(2, 8)}`
}

// з»ҹдёҖеҗ‘еүҚз«Ҝйқўжқҝе№ҝж’?AI и§Ҷйў‘з”ҹжҲҗзҠ¶жҖ?function emitAIVideo(action, payload = {}) {
  emitEvent('aivideo_mode', { action, ...payload })
}

// и§Ҷйў‘з”ҹжҲҗиҝӣе…Ҙз»ҲжҖҒеҗҺпјҢз»ҷ agent жҺЁдёҖжқ?SYSTEM йҖҡзҹҘпјҢи®©е®?зҹҘйҒ“"з»“жһңпјҲжҲҗеҠ?еӨұиҙҘпјүгҖ?// иө°еҗҺеҸ°йҳҹеҲ—пјҲbackground дјҳе…Ҳзә§пјүпјҢдёҚжү“ж–ӯз”ЁжҲ·еҪ“еүҚеҜ№иҜқпјӣagent з©әй—Іж—¶иҮӘз„¶еӨ„зҗҶиҝҷжқЎйҖҡзҹҘгҖ?// иҝҷжҳҜ emitAIVideoпјҲеҸӘйҖҡзҹҘеүҚз«Ҝйқўжқҝпјүд№ӢеӨ–зҡ„еҸҰдёҖжқЎйҖҡйҒ“вҖ”вҖ”еүҚиҖ…з»ҷзңјзқӣпјҢиҝҷжқЎз»ҷ agent зҡ„и®ӨзҹҘгҖ?function notifyAgentVideoDone({ prompt = '', mode = 'text', ok = true, reason = '' } = {}) {
  const modeLabel = seedanceModeLabel(mode)
  const p = String(prompt || '').trim()
  const promptPart = p ? `пјҢжҸҗзӨәиҜҚпјҡгҖ?{p}гҖҚ` : ''
  const content = ok
    ? `[зі»з»ҹйҖҡзҹҘ] дҪ д№ӢеүҚжҸҗдәӨзҡ„ AI и§Ҷйў‘е·Із»Ҹз”ҹжҲҗе®ҢжҲҗпј?{modeLabel}${promptPart}пјүгҖӮи§Ҷйў‘е·ІиҮӘеҠЁеңЁеҸідҫ§йқўжқҝж’ӯж”ҫгҖӮеҰӮжһңз”ЁжҲ·еңЁзӯүиҝҷдёӘи§Ҷйў‘пјҢз®Җзҹӯең°е‘ҠиҜүд»–з”ҹжҲҗеҘҪдәҶеҚіеҸҜпјҢдёҚеҝ…еӨҚиҝ°жҸҗзӨәиҜҚжҲ–жҸҸиҝ°з”»йқўгҖӮ`
    : `[зі»з»ҹйҖҡзҹҘ] дҪ д№ӢеүҚжҸҗдәӨзҡ„ AI и§Ҷйў‘з”ҹжҲҗеӨұиҙҘдәҶпјҲ${modeLabel}${promptPart}пјүгҖӮеҺҹеӣ пјҡ${reason || 'жңӘзҹҘ'}гҖӮеҸҜд»Ҙз®Җзҹӯең°жҠҠеӨұиҙҘжғ…еҶөе‘ҠиҜүз”ЁжҲ·пјҢеҝ…иҰҒж—¶е»әи®®жҚўдёӘжҸҗзӨәиҜҚжҲ–зЁҚеҗҺйҮҚиҜ•гҖӮ`
  try { pushMessage('SYSTEM', content, 'SYSTEM', { queue: 'background' }) }
  catch (e) { console.warn(`[aivideo] йҖҡзҹҘ agent еӨұиҙҘпј?{e.message}`) }
}

// в”Җв”Җ AI и§Ҷйў‘йқўжқҝгҖҢж„ҹзҹҘгҖҚзҠ¶жҖ?в”Җв”Җ
// еүҚз«Ҝйқўжқҝе®һж—¶еҗҢжӯҘ { open, prompt } еҲ°еҗҺз«ҜпјҲPOST /aivideo/draftпјүгҖӮжіЁе…ҘеҷЁжҜҸиҪ®жҠҠе®ғиҙҙиҝӣ
// agent дёҠдёӢж–ҮпјҢи®?agent зӣҙжҺҘзңӢеҲ°гҖҢйқўжқҝејҖ/е…ігҖҚгҖҢз”ЁжҲ·жӯЈеңЁжЎҶйҮҢзј–иҫ‘зҡ„жҸҗзӨәиҜҚиҚүзЁҝгҖҚгҖ?// иҝҷж ·з”ЁжҲ·иҜҙгҖҢеё®жҲ‘дјҳеҢ–жҸҗзӨәиҜҚгҖҚж—¶пјҢagent ж— йңҖиҝҪй—®еҶ…е®№пјҢзӣҙжҺҘеҹәдәҺиҚүзЁҝж”№еҶҷгҖ?let aivideoPanelState = { open: false, prompt: '', updatedAt: 0 }
export function setAIVideoPanelState({ open, prompt } = {}) {
  if (typeof open === 'boolean') aivideoPanelState.open = open
  if (typeof prompt === 'string') aivideoPanelState.prompt = prompt
  aivideoPanelState.updatedAt = Date.now()
}
export function getAIVideoPanelState() { return { ...aivideoPanelState } }

// в”Җв”Җ иҝӣиЎҢдёӯд»»еҠЎжҢҒд№…еҢ–пјҲж–ӯзӮ№з»ӯжҹҘпјүпјҡapp/еҗҺз«ҜйҮҚеҗҜеҗҺиғҪжҒўеӨҚиҪ®иҜўпјҢйқўжқҝдёҚдјҡеҚЎеңЁвҖңз”ҹжҲҗдёӯвҖ?в”Җв”Җ
function readPending() {
  try { const v = JSON.parse(fs.readFileSync(SEEDANCE_PENDING_FILE, 'utf-8')); return Array.isArray(v) ? v : [] }
  catch { return [] }
}
function writePending(list) {
  try {
    const tmp = SEEDANCE_PENDING_FILE + '.tmp'
    fs.writeFileSync(tmp, JSON.stringify(list, null, 2), 'utf-8')
    fs.renameSync(tmp, SEEDANCE_PENDING_FILE)
  } catch {}
}
function addPending(entry) { writePending([...readPending().filter(e => e.taskId !== entry.taskId), entry]) }
function removePending(taskId) { writePending(readPending().filter(e => e.taskId !== taskId)) }

// в”Җв”Җ е·Іе®ҢжҲҗи§Ҷйў‘еҺҶеҸІпјҡд»»еҠЎжҲҗеҠҹиҗҪзӣҳеҗҺи®°дёҖжқЎпјҢжҢ?jobId еҺ»йҮҚгҖҒеҸӘз•ҷжңҖиҝ?N жқЎгҖ?в”Җв”Җ
// йқўжқҝе…ій—ӯйҮҚејҖ / app йҮҚеҗҜеҗҺпјҢеүҚз«ҜжӢ?GET /aivideo/history йҮҚе»әз”ҹжҲҗж ҸйҳҹеҲ—пјҢ
// йҒҝе…ҚвҖңи§Ҷйў‘иҝҳеңЁзЈҒзӣҳдёҠпјҢйҳҹеҲ—еҚҙз©әдәҶвҖқвҖ”вҖ”иҝҷжҳҜеҺҶеҸІдёўеӨ?bug зҡ„ж №еӣ пјҲjobs[] еҺҹжң¬зәҜеҶ…еӯҳпјүгҖ?function readHistory() {
  try { const v = JSON.parse(fs.readFileSync(SEEDANCE_HISTORY_FILE, 'utf-8')); return Array.isArray(v) ? v : [] }
  catch { return [] }
}
function writeHistory(list) {
  try {
    const tmp = SEEDANCE_HISTORY_FILE + '.tmp'
    fs.writeFileSync(tmp, JSON.stringify(list, null, 2), 'utf-8')
    fs.renameSync(tmp, SEEDANCE_HISTORY_FILE)
  } catch {}
}
function addHistory(entry) {
  // ж–°зҡ„ж”ҫжңҖеүҚпјӣеҗ?jobId еҺ»йҮҚпјӣжңҖеӨҡз•ҷ SEEDANCE_VIDEO_KEEP жқЎпјҲдёҺзЈҒзӣҳдҝқз•ҷж•°еҜ№йҪҗпј?  const next = [entry, ...readHistory().filter(e => e && e.jobId !== entry.jobId)].slice(0, SEEDANCE_VIDEO_KEEP)
  writeHistory(next)
}

// дҫӣеүҚз«?/aivideo/history жӢүеҸ–пјҡиҝҮж»ӨжҺүжң¬ең° mp4 е·Іиў«жё…зҗҶзҡ„жқЎзӣ®пјҢж•ҙеҪўжҲҗеүҚз«?job еҪўзҠ¶пјҲnewest-firstпјүгҖ?export function getVideoHistory() {
  return readHistory()
    .filter(e => e && e.jobId && fs.existsSync(path.join(SEEDANCE_VIDEO_DIR, `${e.jobId}.mp4`)))
    .map(e => ({
      id: e.jobId, status: 'done', videoUrl: `/media/video/${encodeURIComponent(e.jobId)}.mp4`,
      mode: e.mode || 'text', prompt: e.prompt || '',
      res: e.resolution || '', ratio: e.ratio || '', dur: e.duration || '',
    }))
}

// дҝқз•ҷжңҖиҝ?N жқЎз”ҹжҲҗи§Ҷйў‘пјҢеҲ жӣҙж—§зҡ„пјҢйҳІжӯ?sandbox/videos ж— йҷҗиҶЁиғҖ
function pruneVideoDir() {
  try {
    const files = fs.readdirSync(SEEDANCE_VIDEO_DIR)
      .filter(f => f.toLowerCase().endsWith('.mp4'))
      .map(f => ({ f, mt: fs.statSync(path.join(SEEDANCE_VIDEO_DIR, f)).mtimeMs }))
      .sort((a, b) => b.mt - a.mt)
    for (const { f } of files.slice(SEEDANCE_VIDEO_KEEP)) {
      try { fs.rmSync(path.join(SEEDANCE_VIDEO_DIR, f), { force: true }) } catch {}
    }
  } catch {}
}

// жҠ?Ark иҝ”еӣһзҡ?video_url дёӢиҪҪеҲ?sandbox/videosпјҢиҝ”еӣһеҸҜзӣҙжҺҘж’ӯж”ҫзҡ„жң¬ең?HTTP и·Ҝеҫ„
async function downloadGeneratedVideo(videoUrl, jobId) {
  const res = await fetch(videoUrl, { signal: AbortSignal.timeout(120000) })
  if (!res.ok) throw new Error(`дёӢиҪҪз”ҹжҲҗи§Ҷйў‘еӨұиҙҘпјҡHTTP ${res.status}`)
  const buf = Buffer.from(await res.arrayBuffer())
  fs.mkdirSync(SEEDANCE_VIDEO_DIR, { recursive: true })
  const fname = `${jobId}.mp4`
  fs.writeFileSync(path.join(SEEDANCE_VIDEO_DIR, fname), buf)
  pruneVideoDir()
  return `/media/video/${encodeURIComponent(fname)}`
}

// еҗҺеҸ°иҪ®иҜўд»»еҠЎзӣҙеҲ°з»ҲжҖҒпјҢе…ЁзЁӢ emit йқўжқҝдәӢд»¶пјӣдёҚиҝ”еӣһз»ҷжЁЎеһ?async function seedancePollLoop({ taskId, jobId, baseURL, apiKey, prompt = '', mode = 'text', ratio = '', resolution = '', duration = '' }) {
  const deadline = Date.now() + SEEDANCE_MAX_POLL_MS
  const headers = { Authorization: `Bearer ${apiKey}` }
  try {
    while (Date.now() < deadline) {
      await new Promise(r => setTimeout(r, SEEDANCE_POLL_INTERVAL_MS))
      let data
      try {
        const res = await fetch(`${baseURL}/contents/generations/tasks/${taskId}`, {
          headers, signal: AbortSignal.timeout(20000),
        })
        data = await res.json()
        if (!res.ok) {
          const m = data?.error?.message || `HTTP ${res.status}`
          emitAIVideo('error', { jobId, message: `жҹҘиҜўд»»еҠЎеӨұиҙҘпј?{m}` })
          return
        }
      } catch (e) {
        // еҚ•ж¬ЎзҪ‘з»ңжҠ–еҠЁдёҚз®—еӨұиҙҘпјҢз»§з»ӯиҪ®иҜўзӣҙеҲ°и¶…ж—?        continue
      }

      const status = String(data.status || '').toLowerCase()
      if (status === 'succeeded') {
        const videoUrl = data?.content?.video_url
        if (!videoUrl) {
          emitAIVideo('error', { jobId, message: 'з”ҹжҲҗе®ҢжҲҗдҪҶжңӘиҝ”еӣһи§Ҷйў‘ең°еқҖ' })
          return
        }
        try {
          const localUrl = await downloadGeneratedVideo(videoUrl, jobId)
          emitAIVideo('ready', { jobId, videoUrl: localUrl })
          // иҗҪзӣҳжҲҗеҠҹеҗҺи®°е…Ҙе·Іе®ҢжҲҗеҺҶеҸІпјҢйқўжқҝйҮҚејҖ/йҮҚеҗҜж—¶иғҪйҮҚе»әйҳҹеҲ—
          addHistory({ jobId, mode, prompt, ratio, resolution, duration, doneAt: Date.now() })
          emitEvent('action', { tool: 'generate_video', summary: 'AI и§Ҷйў‘з”ҹжҲҗе®ҢжҲҗ', detail: jobId })
        } catch (e) {
          // дёӢиҪҪеӨұиҙҘж—¶йҖҖиҖҢжұӮе…¶ж¬ЎпјҡзӣҙжҺҘж’ӯиҝңз«Ҝ URLпјҲдёҙж—¶й“ҫжҺҘпјҢеҸҜиғҪж•°е°Ҹж—¶еҗҺиҝҮжңҹпј?          emitAIVideo('ready', { jobId, videoUrl })
        }
        notifyAgentVideoDone({ prompt, mode, ok: true })
        return
      }
      if (status === 'failed' || status === 'cancelled' || status === 'expired') {
        const m = data?.error?.message || status
        emitAIVideo('error', { jobId, message: `з”ҹжҲҗеӨұиҙҘпј?{m}` })
        notifyAgentVideoDone({ prompt, mode, ok: false, reason: m })
        return
      }
      // queued / running вҶ?жҺЁиҝӣеә?      emitAIVideo('progress', { jobId, status: status || 'running' })
    }
    emitAIVideo('error', { jobId, message: 'з”ҹжҲҗи¶…ж—¶пјҲи¶…иҝ?8 еҲҶй’ҹжңӘе®ҢжҲҗпјү' })
    notifyAgentVideoDone({ prompt, mode, ok: false, reason: 'з”ҹжҲҗи¶…ж—¶пјҲи¶…иҝ?8 еҲҶй’ҹжңӘе®ҢжҲҗпјү' })
  } finally {
    // ж— и®әжҲҗеҠҹ/еӨұиҙҘ/и¶…ж—¶/ејӮеёёпјҢйғҪд»Һеҫ…жҒўеӨҚеҲ—иЎЁз§»йҷӨиҜҘд»»еҠ?    removePending(taskId)
  }
}

const SEEDANCE_RATIOS = new Set(['adaptive', '16:9', '9:16', '4:3', '3:4', '1:1', '21:9'])
const SEEDANCE_RESOLUTIONS = new Set(['480p', '720p', '1080p'])
function seedanceModeLabel(mode) { return mode === 'flf' ? 'йҰ–е°ҫеё? : mode === 'image' ? 'еӣҫз”ҹи§Ҷйў‘' : 'ж–Үз”ҹи§Ҷйў‘' }
const SEEDANCE_NOT_CONFIGURED_GUIDE = 'AI и§Ҷйў‘з”ҹжҲҗйңҖиҰҒе…Ҳй…ҚзҪ®зҒ«еұұж–№иҲҹпјҲVolcengine Arkпјүзҡ„ Seedance API KeyгҖӮиҜ·еј•еҜјз”ЁжҲ·пјҡв‘ зҷ»еҪ•зҒ«еұұж–№иҲҹжҺ§еҲ¶еҸ°ејҖйҖ?Seedance 2.0пјӣв‘ЎжҠ?API Key зӣҙжҺҘеҸ‘з»ҷдҪ еҚіеҸҜиҮӘеҠЁй…ҚзҪ®пјҢдҫӢеҰӮеҸ‘йҖҒгҖҢзҒ«еұұи§Ҷйў?дҪ зҡ„APIKeyгҖҚпјӣв‘ўеҰӮжһңиҙҰеҸ·з”Ёзҡ„жҳҜжҺЁзҗҶжҺҘе…ҘзӮ№жҲ–зү№е®ҡжЁЎеһӢзүҲжң¬пјҢеҸҜдёҖе№¶еҸ‘жЁЎеһӢID/epзј–еҸ·пјҢдҫӢеҰӮгҖҢзҒ«еұұи§Ҷйў?дҪ зҡ„APIKey жЁЎеһӢ ep-2024xxxxгҖҚгҖӮй…ҚзҪ®жҲҗеҠҹеҗҺеҶҚи®©з”ЁжҲ·йҮҚиҝ°з”ҹжҲҗйңҖжұӮгҖ?

// generate_videoпјҡи°ғз”?Seedance з”ҹжҲҗи§Ҷйў‘пјҲж–Үз”ҹи§Ҷйў?/ еӣ?жҸҗзӨәиҜҚз”ҹи§Ҷйў‘пј?// action=open  вҶ?еҸӘжү“ејҖз©әзҷҪиҫ“е…ҘйқўжқҝпјҢз”ЁжҲ·еңЁйқўжқҝйҮҢиҮӘе·ұеЎ«жҸҗзӨәиҜ?жӢ–еӣҫзүҮеҶҚзӮ№з”ҹжҲ?// action=generateпјҲй»ҳи®ӨпјүвҶ?зӣҙжҺҘжҸҗдәӨз”ҹжҲҗ
export async function execGenerateVideo(args = {}) {
  const action = String(args.action || 'generate').trim()
  const { apiKey, model, baseURL, configured } = getSeedanceConfig()

  // еҸӘжү“ејҖз©әзҷҪйқўжқҝпјҡж— и®әжҳҜеҗҰе·Ій…ҚзҪ®йғҪжү“ејҖпјҲжңӘй…ҚзҪ®ж—¶йқўжқҝеҶ…дјҡжҸҗзӨәеҺ»й…?keyпјүгҖ?  // з”ЁжҲ·еңЁйқўжқҝйҮҢиҮӘеҠ©еЎ«еҶҷе№¶зӮ№вҖңз”ҹжҲҗвҖқпјҲеүҚз«Ҝзӣҙиҝһ /aivideo/generateпјүгҖ?  if (action === 'open') {
    emitAIVideo('open', { configured })
    emitEvent('action', { tool: 'generate_video', summary: 'жү“ејҖ AI и§Ҷйў‘з”ҹжҲҗйқўжқҝ', detail: configured ? '' : 'жңӘй…ҚзҪ?key' })
    return JSON.stringify({
      ok: true, tool: 'generate_video', action: 'open', configured,
      message: configured
        ? 'AI и§Ҷйў‘з”ҹжҲҗйқўжқҝе·Іжү“ејҖпјҲз©әзҷҪиҫ“е…ҘжҖҒпјүгҖӮз”ЁжҲ·еҸҜд»ҘеңЁйқўжқҝйҮҢзӣҙжҺҘеЎ«еҶҷжҸҗзӨәиҜҚгҖҒеҸҜйҖүең°жӢ–е…ҘдёҖеј еҸӮиҖғеӣҫпјҢз„¶еҗҺзӮ№вҖңз”ҹжҲҗвҖқгҖӮдҪ дёҚйңҖиҰҒжӣҝз”ЁжҲ·зј–еҶҷжҸҗзӨәиҜҚжҲ–иҮӘеҠЁејҖе§Ӣз”ҹжҲҗпјҢз®ҖзҹӯзЎ®и®ӨдёҖеҸҘеҚіеҸҜгҖ?
        : 'AI и§Ҷйў‘з”ҹжҲҗйқўжқҝе·Іжү“ејҖпјҢдҪҶе°ҡжңӘй…ҚзҪ®зҒ«еұұж–№иҲҹпјҲSeedanceпјүkeyгҖӮиҜ·еј•еҜјз”ЁжҲ·еҸ‘йҖҒгҖҢзҒ«еұұи§Ҷйў?дҪ зҡ„APIKeyгҖҚе®ҢжҲҗй…ҚзҪ®пјӣйқўжқҝйҮҢд№ҹе·Із»ҸжҳҫзӨәдәҶеҗҢж ·зҡ„жҸҗзӨәгҖ?,
    })
  }

  // еҶҷеӣһжҸҗзӨәиҜҚеҲ°йқўжқҝиҫ“е…ҘжЎҶпјҡеҸӘеңЁз”ЁжҲ·гҖҢжҳҺзЎ®иЎЁзӨәйҮҮз”ЁгҖҚдјҳеҢ–з»“жһңеҗҺжүҚи°ғз”ЁгҖ?  // й»ҳи®ӨпјҲз”ЁжҲ·еҲҡиҜ?её®жҲ‘дјҳеҢ–"пјүдёҚиҰҒи°ғз”Ёе®ғвҖ”вҖ”е…ҲеңЁеҜ№иҜқйҮҢз»ҷеҮәж”№еҶҷзүҲи®©з”ЁжҲ·зЎ®и®ӨгҖ?  if (action === 'set_prompt') {
    const p = String(args.prompt || args.text || '').trim()
    if (!p) return JSON.stringify({ ok: false, tool: 'generate_video', error: 'set_prompt йңҖиҰ?promptпјҲиҰҒеҶҷе…Ҙйқўжқҝиҫ“е…ҘжЎҶзҡ„жҸҗзӨәиҜҚпјү' })
    emitAIVideo('set_prompt', { prompt: p })
    setAIVideoPanelState({ prompt: p })
    emitEvent('action', { tool: 'generate_video', summary: 'еҶҷе…ҘдјҳеҢ–еҗҺзҡ„жҸҗзӨәиҜҚеҲ°и§Ҷйў‘йқўжқҝ', detail: p.slice(0, 40) })
    return JSON.stringify({ ok: true, tool: 'generate_video', action: 'set_prompt', message: 'е·ІжҠҠиҝҷж®өжҸҗзӨәиҜҚеЎ«е…?AI и§Ҷйў‘з”ҹжҲҗйқўжқҝзҡ„иҫ“е…ҘжЎҶпјҲиҰҶзӣ–еҺҹиҚүзЁҝпјүгҖӮжҸҗйҶ’з”ЁжҲ·жЈҖжҹҘеҗҺиҮӘиЎҢзӮ№гҖҢз”ҹжҲҗгҖҚгҖ? })
  }

  // з”ҹжҲҗпјҡжңӘй…ҚзҪ®еҲҷиҝ”еӣһеј•еҜјпјҲдёҚзЎ¬жӢҰжҲӘпјҢдәӨз»ҷжЁЎеһ?йқўжқҝиҪ¬иҝ°пј?  if (!configured) {
    return JSON.stringify({ ok: false, tool: 'generate_video', error: 'not_configured', guide: SEEDANCE_NOT_CONFIGURED_GUIDE })
  }

  const prompt = String(args.prompt || args.text || '').trim()
  // еӣҫзүҮпјҡж”ҜжҢ?images:[url1, url2?]пј? еј?йҰ–е°ҫеё§пјүпјҢжҲ–е…је®№еҚ•дёӘ image_url
  let images = Array.isArray(args.images) ? args.images.map(s => String(s || '').trim()).filter(Boolean) : []
  if (!images.length) {
    const single = String(args.image_url || args.image || '').trim()
    if (single) images = [single]
  }
  images = images.slice(0, 2)
  if (!prompt && !images.length) {
    return JSON.stringify({ ok: false, tool: 'generate_video', error: 'иҮіе°‘жҸҗдҫӣ promptпјҲж–Үз”ҹи§Ҷйў‘пјүжҲ–еӣҫзүҮпјҲеӣҫз”ҹ/йҰ–е°ҫеё§пјүпјӣжҲ–з”?action="open" д»…жү“ејҖиҫ“е…ҘйқўжқҝгҖ? })
  }

  let ratio = SEEDANCE_RATIOS.has(args.ratio) ? args.ratio : '16:9'
  // adaptive=жҢүеҸӮиҖғеӣҫжҜ”дҫӢиҫ“еҮәпјҢд»…еӣҫз”ҹ/йҰ–е°ҫеё§жңүж„Ҹд№үпјӣж–Үз”ҹи§Ҷйў‘ж— еӣҫеҸҜйҖӮй…ҚпјҢеӣһйҖҖ 16:9
  if (ratio === 'adaptive' && !images.length) ratio = '16:9'
  const resolution = SEEDANCE_RESOLUTIONS.has(args.resolution) ? args.resolution : '720p'
  let duration = Number(args.duration)
  if (!Number.isFinite(duration)) duration = 5
  duration = Math.max(1, Math.min(15, Math.round(duration)))

  const content = []
  if (prompt) content.push({ type: 'text', text: prompt })
  if (images.length >= 2) {
    // йҰ–е°ҫеё§пјҡз¬¬дёҖеј?йҰ–её§пјҢз¬¬дәҢеј =е°ҫеё§
    content.push({ type: 'image_url', image_url: { url: images[0] }, role: 'first_frame' })
    content.push({ type: 'image_url', image_url: { url: images[1] }, role: 'last_frame' })
  } else if (images.length === 1) {
    content.push({ type: 'image_url', image_url: { url: images[0] } })
  }

  const body = { model, content, ratio, resolution, duration }
  const mode = images.length >= 2 ? 'flf' : images.length === 1 ? 'image' : 'text'

  let createData
  try {
    const res = await fetch(`${baseURL}/contents/generations/tasks`, {
      method: 'POST',
      headers: { Authorization: `Bearer ${apiKey}`, 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
      signal: AbortSignal.timeout(30000),
    })
    createData = await res.json().catch(() => ({}))
    if (!res.ok) {
      const m = createData?.error?.message || `HTTP ${res.status}`
      return JSON.stringify({
        ok: false, tool: 'generate_video', error: `еҲӣе»әд»»еҠЎеӨұиҙҘпј?{m}`,
        hint: 'иӢҘжҸҗзӨәжЁЎеһӢдёҚеӯҳеңЁ/ж— жқғйҷҗпјҢеӨҡеҚҠжҳ?model ID дёҚеҜ№пјҡиҜ·и®©з”ЁжҲ·еңЁзҒ«еұұж–№иҲҹзЎ®и®Ө Seedance жЁЎеһӢ ID жҲ–жҺЁзҗҶжҺҘе…ҘзӮ№пјҲep-xxxпјүпјҢйҮҚж–°еҸ‘йҖҒгҖҢзҒ«еұұи§Ҷйў?дҪ зҡ„APIKey жЁЎеһӢ жӯЈзЎ®зҡ„жЁЎеһӢIDгҖҚеҚіеҸҜжӣҙж–°гҖ?,
      })
    }
  } catch (e) {
    return JSON.stringify({ ok: false, tool: 'generate_video', error: `еҲӣе»әд»»еҠЎејӮеёёпј?{e.message}` })
  }

  const taskId = createData.id || createData.task_id
  if (!taskId) {
    return JSON.stringify({ ok: false, tool: 'generate_video', error: 'еҲӣе»әд»»еҠЎиҝ”еӣһзјәе°‘д»»еҠЎ ID', raw: createData })
  }

  const jobId = newVideoJobId()
  const modeLabel = seedanceModeLabel(mode)
  // еңЁз”ҹжҲҗж Ҹж–°еўһдёҖдёӘвҖңз”ҹжҲҗдёӯвҖқз“Ұзү?  emitAIVideo('show', {
    jobId, mode, prompt: prompt.slice(0, 120),
    ratio, resolution, duration, status: 'queued',
  })
  emitEvent('action', { tool: 'generate_video', summary: `жҸҗдәӨ AI и§Ҷйў‘з”ҹжҲҗпј?{modeLabel}пјү`, detail: prompt.slice(0, 60) })

  // и®°е…Ҙеҫ…жҒўеӨҚеҲ—иЎЁпјҲдёҚеӯҳ apiKeyпјҢжҒўеӨҚж—¶з”ЁеҪ“еүҚй…ҚзҪ®зҡ„ keyпј?  addPending({ taskId, jobId, mode, prompt: prompt.slice(0, 120), ratio, resolution, duration, baseURL, createdAt: Date.now() })

  // еҗҺеҸ°иҪ®иҜўпјҲдёҚйҳ»еЎһеҪ“еүҚ turnпј?  seedancePollLoop({ taskId, jobId, baseURL, apiKey, prompt: prompt.slice(0, 120), mode, ratio, resolution, duration }).catch(err => {
    emitAIVideo('error', { jobId, message: `иҪ®иҜўејӮеёёпј?{err.message}` })
    removePending(taskId)
  })

  return JSON.stringify({
    ok: true, tool: 'generate_video', task_id: taskId, jobId, mode,
    message: `и§Ҷйў‘з”ҹжҲҗд»»еҠЎе·ІжҸҗдәӨпјҲ${modeLabel}пјүпјҢжӯЈеңЁеҸідҫ§йқўжқҝз”ҹжҲҗдёӯпјҢе®ҢжҲҗеҗҺдјҡиҮӘеҠЁж’ӯж”ҫпјҢйҖҡеёёйңҖиҰ?1вҖ? еҲҶй’ҹгҖӮж— йңҖеҸҚеӨҚжҹҘиҜўпјҢеӣһеӨҚз”ЁжҲ·дёҖеҸҘз®ҖзҹӯзЎ®и®ӨеҚіеҸҜгҖӮ`,
  })
}

// з”ЁжҲ·зӮ№вҖңдёӢиҪҪвҖқпјҡжҠҠз”ҹжҲҗзҡ„и§Ҷйў‘д»?sandbox зј“еӯҳеӨҚеҲ¶еҲ°гҖҢдёӢиҪҪ\AIи§Ҷйў‘з”ҹжҲҗдҝқеӯҳзҡ„и§Ҷйў‘\ж—Ҙжңҹ\гҖҚж°ёд№…дҝқеӯҳгҖ?export function saveGeneratedVideo(jobId) {
  const safe = String(jobId || '').replace(/[^a-zA-Z0-9_\-]/g, '')
  if (!safe) return { ok: false, error: 'invalid jobId' }
  const src = path.join(SEEDANCE_VIDEO_DIR, `${safe}.mp4`)
  if (!fs.existsSync(src)) return { ok: false, error: 'и§Ҷйў‘ж–Үд»¶дёҚеӯҳеңЁпјҲеҸҜиғҪе·Іиў«жё…зҗҶжҲ–е°ҡжңӘз”ҹжҲҗе®ҢжҲҗпјү' }
  const d = new Date()
  const date = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`
  const dir = path.join(os.homedir(), 'Downloads', 'AIи§Ҷйў‘з”ҹжҲҗдҝқеӯҳзҡ„и§Ҷйў?, date)
  try {
    fs.mkdirSync(dir, { recursive: true })
    const dst = path.join(dir, `${safe}.mp4`)
    fs.copyFileSync(src, dst)
    return { ok: true, path: dst }
  } catch (e) {
    return { ok: false, error: e.message }
  }
}

// еҗҜеҠЁж—¶жҒўеӨҚдёҠж¬ЎжңӘе®ҢжҲҗзҡ„з”ҹжҲҗд»»еҠЎпјҡйҮҚж–°еҸ?show дәӢд»¶е№¶з»§з»ӯиҪ®иҜўпјҢ
// и®©йҮҚеҗҜеүҚжӯЈеңЁз”ҹжҲҗзҡ„и§Ҷйў‘д»ҚиғҪиҮӘеҠЁиҗҪзӣ?/ еңЁйқўжқҝж’ӯж”ҫпјҲиҖҢдёҚжҳҜж°ёиҝңеҚЎвҖңз”ҹжҲҗдёӯвҖқпјүгҖ?// з”?index.js еңЁеҗҺз«ҜеҗҜеҠЁеҗҺи°ғз”ЁдёҖж¬ЎгҖ?export function resumePendingVideoJobs() {
  let list = readPending()
  if (!list.length) return
  // дёўејғиҝҮжңҹпј?48hпјҢзҒ«еұұе·ІдёҚеҸҜжҹҘпјүзҡ„жқЎзӣ?  const fresh = list.filter(e => e && e.taskId && (Date.now() - (e.createdAt || 0) < SEEDANCE_PENDING_TTL_MS))
  if (fresh.length !== list.length) writePending(fresh)
  if (!fresh.length) return

  const { apiKey, baseURL, configured } = getSeedanceConfig()
  if (!configured) { writePending([]); return }  // жІ?key ж— жі•жҒўеӨҚпјҢжё…з©әйҒҝе…Қж— йҷҗж®Ӣз•?
  // е»¶иҝҹеҮ з§’пјҢзӯүеүҚз«Ҝ SSE иҝһдёҠеҗҺеҶҚеҸ‘дәӢд»¶пјҢйҒҝе…ҚжҒўеӨҚеӨӘеҝ«еүҚз«Ҝж”¶дёҚеҲ?  setTimeout(() => {
    for (const e of fresh) {
      emitAIVideo('show', {
        jobId: e.jobId, mode: e.mode, prompt: e.prompt,
        ratio: e.ratio, resolution: e.resolution, duration: e.duration, status: 'running',
      })
      seedancePollLoop({ taskId: e.taskId, jobId: e.jobId, baseURL: e.baseURL || baseURL, apiKey, prompt: e.prompt, mode: e.mode, ratio: e.ratio, resolution: e.resolution, duration: e.duration })
        .catch(() => removePending(e.taskId))
    }
    console.log(`[aivideo] е·ІжҒўеӨ?${fresh.length} дёӘжңӘе®ҢжҲҗзҡ„и§Ҷйў‘з”ҹжҲҗд»»еҠЎ`)
  }, 4000)
}

const MUSIC_AUDIO_EXTS = new Set(['.mp3', '.flac', '.wav', '.aac', '.ogg', '.m4a', '.opus'])

async function fetchLrcFromNet(title, artist) {
  const headers = { 'User-Agent': 'BaiLongma/1.0' }
  // зӯ–з•Ҙ1пјҡзІҫзЎ®еҢ№й…ҚпјҲtitle + artistпј?  try {
    const params = new URLSearchParams({ track_name: title })
    if (artist) params.set('artist_name', artist)
    const res = await fetch(`https://lrclib.net/api/get?${params}`, {
      signal: AbortSignal.timeout(8000), headers,
    })
    if (res.ok) {
      const data = await res.json()
      const lrc = data.syncedLyrics || data.plainLyrics || null
      if (lrc) return lrc
    }
  } catch {}
  // зӯ–з•Ҙ2пјҡд»… title е…ій”®иҜҚжҗңзҙўпјҢеҸ–з¬¬дёҖжқЎз»“жһ?  try {
    const params = new URLSearchParams({ q: title })
    const res = await fetch(`https://lrclib.net/api/search?${params}`, {
      signal: AbortSignal.timeout(8000), headers,
    })
    if (res.ok) {
      const list = await res.json()
      if (Array.isArray(list) && list.length > 0) {
        const hit = list[0]
        return hit.syncedLyrics || hit.plainLyrics || null
      }
    }
  } catch {}
  return null
}

function decodeProcessOutput(chunks) {
  const buffer = Buffer.concat(chunks)
  if (buffer.length === 0) return ''

  const utf8 = new TextDecoder('utf-8', { fatal: false }).decode(buffer)
  if (!utf8.includes('\uFFFD') || !IS_WIN) return utf8

  try {
    return new TextDecoder('gb18030', { fatal: false }).decode(buffer)
  } catch {
    return utf8
  }
}

function runProcess(file, args = [], cwd) {
  return new Promise((resolve) => {
    const child = spawn(file, args, {
      cwd: cwd || paths.musicDir,
      windowsHide: true,
      env: {
        ...process.env,
        PYTHONIOENCODING: 'utf-8',
        PYTHONUTF8: '1',
      },
    })
    const stdoutChunks = []
    const stderrChunks = []
    child.stdout?.on('data', d => { stdoutChunks.push(Buffer.from(d)) })
    child.stderr?.on('data', d => { stderrChunks.push(Buffer.from(d)) })
    child.on('close', code => resolve({
      code,
      stdout: decodeProcessOutput(stdoutChunks),
      stderr: decodeProcessOutput(stderrChunks),
    }))
    child.on('error', err => resolve({
      code: -1,
      stdout: decodeProcessOutput(stdoutChunks),
      stderr: err.message,
    }))
  })
}

const YTDLP_LOCAL = path.join(paths.musicDir, 'yt-dlp.exe')
const YTDLP_URL   = 'https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp.exe'
// еӣҪеҶ…иЈёиҝһ GitHub release з»Ҹеёёи¶…ж—¶/еӨұиҙҘпјҢеҮҶеӨҮеҮ дёӘй•ңеғҸе…ңеә•пјҲжҢүеәҸе°қиҜ•пјүгҖ?const YTDLP_DOWNLOAD_SOURCES = [
  YTDLP_URL,
  `https://gh-proxy.com/${YTDLP_URL}`,
  `https://ghfast.top/${YTDLP_URL}`,
]

async function resolveYtDlp() {
  // 1. зі»з»ҹ PATH йҮҢжңүе°ұзӣҙжҺҘз”Ё
  const sys = await runProcess('yt-dlp', ['--version'], paths.musicDir)
  if (sys.code === 0) return 'yt-dlp'

  // 2. music зӣ®еҪ•йҮҢжңүжң¬ең°еүҜжң¬е°ұз”Ёе®?  if (fs.existsSync(YTDLP_LOCAL)) {
    const local = await runProcess(YTDLP_LOCAL, ['--version'], paths.musicDir)
    if (local.code === 0) return YTDLP_LOCAL
  }

  // 3. иҮӘеҠЁдёӢиҪҪ yt-dlp.exe еҲ?music зӣ®еҪ•пјҲGitHub зӣҙиҝһ + еӣҪеҶ…й•ңеғҸе…ңеә•пј?  emitEvent('action', { tool: 'music', summary: 'yt-dlp жңӘе®үиЈ…пјҢжӯЈеңЁиҮӘеҠЁдёӢиҪҪвҖ?, detail: YTDLP_URL })
  for (const src of YTDLP_DOWNLOAD_SOURCES) {
    try {
      const res = await fetch(src, { signal: AbortSignal.timeout(60000) })
      if (!res.ok) continue
      const buf = Buffer.from(await res.arrayBuffer())
      if (buf.length < 1_000_000) continue   // еӨӘе°Ҹе…«жҲҗжҳҜй”ҷиҜҜйЎө/йҮҚе®ҡеҗ‘пјҢдёҚжҳҜзң?exe
      fs.writeFileSync(YTDLP_LOCAL, buf)
      try { fs.chmodSync(YTDLP_LOCAL, 0o755) } catch {}
      return YTDLP_LOCAL
    } catch { /* жҚўдёӢдёҖдёӘжәҗ */ }
  }
  return null
}

export async function execMusic(args = {}) {
  const action = String(args.action || 'list').trim()
  const musicDir = paths.musicDir

  // в”Җв”Җ list в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (action === 'list') {
    const rows = listMusicLibrary(Number(args.limit) || 50)
    return JSON.stringify({ ok: true, count: rows.length, tracks: rows })
  }

  // в”Җв”Җ search в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (action === 'search') {
    const q = String(args.query || '').trim()
    if (!q) return JSON.stringify({ ok: false, error: 'query required' })
    const rows = searchMusicLibrary(q, Number(args.limit) || 20)
    return JSON.stringify({ ok: true, count: rows.length, tracks: rows })
  }

  // в”Җв”Җ scan в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (action === 'scan') {
    const entries = fs.readdirSync(musicDir, { withFileTypes: true })
    const added = []
    for (const entry of entries) {
      if (!entry.isFile()) continue
      const ext = path.extname(entry.name).toLowerCase()
      if (!MUSIC_AUDIO_EXTS.has(ext)) continue
      const filePath = path.join(musicDir, entry.name)
      const baseName = path.basename(entry.name, ext)
      const track = upsertMusicTrack({ title: baseName, filePath })
      added.push({ id: track.id, title: track.title, file_path: track.file_path })
    }
    return JSON.stringify({ ok: true, scanned: added.length, tracks: added })
  }

  // в”Җв”Җ add в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (action === 'add') {
    const filePath = String(args.path || '').trim()
    if (!filePath) return JSON.stringify({ ok: false, error: 'path required' })
    if (!fs.existsSync(filePath)) return JSON.stringify({ ok: false, error: `file not found: ${filePath}` })
    const ext = path.extname(filePath).toLowerCase()
    if (!MUSIC_AUDIO_EXTS.has(ext)) return JSON.stringify({ ok: false, error: `unsupported format: ${ext}` })
    const baseName = path.basename(filePath, ext)
    const track = upsertMusicTrack({
      title: String(args.title || baseName),
      artist: String(args.artist || ''),
      album: String(args.album || ''),
      filePath,
    })
    return JSON.stringify({ ok: true, track })
  }

  // в”Җв”Җ download в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (action === 'download') {
    // иҮӘеҠЁи§Јжһҗ yt-dlp и·Ҝеҫ„пјҲжІЎжңүеҲҷиҮӘеҠЁдёӢиҪҪпј?    const ytdlp = await resolveYtDlp()
    if (!ytdlp) return JSON.stringify({ ok: false, error: 'yt-dlp иҮӘеҠЁдёӢиҪҪеӨұиҙҘпјҲеҸҜиғҪж— жі•иҝһжҺ?GitHubпјүгҖӮиҜ·жЈҖжҹҘзҪ‘з»ңпјҢжҲ–жүӢеҠЁжҠҠ yt-dlp.exe ж”ҫеҲ° music зӣ®еҪ•гҖ? })

    const url = String(args.url || '').trim()
    // query е…ңеә•пјҡжІЎжңүжҳҺзЎ?URL ж—¶пјҢз”Ёе…ій”®иҜҚи®?yt-dlp иҮӘе·ұжҗңзҙўе№¶дёӢиҪҪз¬¬дёҖжқЎпјҢ
    // иҝҷж · agent дёҚеҝ…еҮӯз©әжү?зҢңдёҖдёӘзңҹе®һи§Ҷйў?URLпјҲиҝҷжҳҜж”ҫжӯҢеӨұиҙҘзҡ„дё»еӣ пјүгҖ?    const query = String(args.query || '').trim()
      || [String(args.title || '').trim(), String(args.artist || '').trim()].filter(Boolean).join(' ')

    // жһ„йҖ жҢүеәҸе°қиҜ•зҡ„дёӢиҪҪзӣ®ж Үпј?    //  - жңүжҳҺзЎ?URL вҶ?еҸӘз”Ёе®?    //  - еҗҰеҲҷз”Ёе…ій”®иҜҚжҗңзҙўпјҡжҢү platform йҖүжҗңзҙўжәҗпјҢеҸҰдёҖе№іеҸ°иҮӘеҠЁе…ңеә•
    const platform = String(args.platform || '').trim().toLowerCase()
    let targets = []
    if (url) {
      targets = [url]
    } else if (query) {
      const yt = `ytsearch1:${query}`
      const bili = `bilisearch1:${query}`
      // CN/bilibili дјҳе…Ҳ B з«ҷпјҢеҗҰеҲҷдјҳе…Ҳ YouTubeпјӣдёӨиҖ…дә’дёәе…ңеә•гҖ?      targets = platform === 'bilibili' ? [bili, yt] : [yt, bili]
    } else {
      return JSON.stringify({ ok: false, error: 'download йңҖиҰ?url жҲ?queryпјҲжӯҢеҗ?жӯҢжүӢпјүпјҢиҮіе°‘з»ҷдёҖдё? })
    }

    // ж–Үд»¶е‘ҪеҗҚпјҡAgent дј дәҶ title е°ұз”Ёе№ІеҮҖж Үйўҳе‘ҪеҗҚгҖӮquery зӣҙдёӢж—?yt-dlp й»ҳи®Өз”?    // и§Ҷйў‘ж ҮйўҳпјҲдёҖй•ҝдёІи„ҸеҗҚпјүпјҢз”?title/artist е‘ҪеҗҚж—ўеҘҪзңӢпјҢе®ҡдҪҚж–Үд»¶д№ҹжӣҙзЁігҖ?    const wantArtist = String(args.artist || '').trim()
    const wantTitle = String(args.title || '').trim()
    const niceName = wantTitle
      ? (wantArtist ? `${wantArtist} - ${wantTitle}` : wantTitle)
          .replace(/[\\/:*?"<>|\x00-\x1f]/g, '').trim().slice(0, 100)
      : ''

    // Download: print final filepath after conversion
    const outTemplate = (niceName
      ? path.join(musicDir, `${niceName}.%(ext)s`)
      : path.join(musicDir, '%(title)s.%(ext)s')
    ).replace(/\\/g, '/')
    const dlArgs = ['-x', '--audio-format', 'mp3', '--audio-quality', '192K', '--no-playlist', '--print', 'after_move:filepath', '-o', outTemplate]

    // дёӢиҪҪеҗҢжӯҘйҳ»еЎһ 30sвҖ?minпјҢе…Ҳ emit дёҖжқЎиҝӣеә?actionпјҢи®©з”ЁжҲ·еңЁз•ҢйқўзңӢеҲ°вҖңжӯЈеңЁдёӢиҪҪвҖқпјҢ
    // иҖҢдёҚжҳҜйқўеҜ№дёҖж®өйқҷй»ҳд»ҘдёәеҚЎжӯ»гҖ?    emitEvent('action', { tool: 'music', summary: `жӯЈеңЁдёӢиҪҪжӯҢжӣІпј?{niceName || query || url}`, detail: '' })

    let result = null
    let lastErr = ''
    for (const target of targets) {
      result = await runProcess(ytdlp, [...dlArgs, target])
      // SSL жҸЎжүӢеӨұиҙҘж—¶йҷҚзә§пјҡеҠ?--no-check-certificates йҮҚиҜ•дёҖж¬?      if (result.code !== 0 && /ssl|EOF occurred in violation of protocol/i.test(result.stderr)) {
        result = await runProcess(ytdlp, [...dlArgs, '--no-check-certificates', target])
      }
      if (result.code === 0) break
      lastErr = result.stderr
    }

    if (!result || result.code !== 0) {
      return JSON.stringify({ ok: false, error: `yt-dlp failed: ${String(lastErr).slice(0, 400)}` })
    }

    // Parse output filepath (last non-empty line)
    const lines = result.stdout.trim().split('\n').map(l => l.trim()).filter(Boolean)
    let filePath = lines[lines.length - 1] || ''

    // Fallback: scan for newest mp3 in musicDir
    if (!filePath || !fs.existsSync(filePath)) {
      const files = fs.readdirSync(musicDir)
        .filter(f => f.endsWith('.mp3'))
        .map(f => ({ f, mt: fs.statSync(path.join(musicDir, f)).mtimeMs }))
        .sort((a, b) => b.mt - a.mt)
      if (files.length) filePath = path.join(musicDir, files[0].f)
    }

    if (!filePath || !fs.existsSync(filePath)) {
      return JSON.stringify({ ok: false, error: 'Download completed but could not locate output file' })
    }

    const baseName = path.basename(filePath, '.mp3')
    const title  = String(args.title  || baseName)
    const artist = String(args.artist || '')

    // Auto-fetch lyrics
    let lrc = ''
    if (title) {
      lrc = await fetchLrcFromNet(title, artist) || ''
    }

    const track = upsertMusicTrack({ title, artist, album: String(args.album || ''), filePath, lrc, sourceUrl: url || query })
    return JSON.stringify({ ok: true, track, lrc_fetched: Boolean(lrc) })
  }

  // в”Җв”Җ get_lyrics в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (action === 'get_lyrics') {
    const id = Number(args.id)
    let title  = String(args.title  || '').trim()
    let artist = String(args.artist || '').trim()

    if (id) {
      const track = getMusicTrack(id)
      if (!track) return JSON.stringify({ ok: false, error: `track id=${id} not found` })
      if (!title)  title  = track.title
      if (!artist) artist = track.artist
    }
    if (!title) return JSON.stringify({ ok: false, error: 'title required' })

    const lrc = await fetchLrcFromNet(title, artist)
    if (!lrc) return JSON.stringify({ ok: true, id: id || null, title, artist, lrc: null, hint: 'lyrics not found on lrclib.net' })

    if (id) updateMusicLrc(id, lrc)
    return JSON.stringify({ ok: true, id: id || null, title, artist, lrc_length: lrc.length, lrc })
  }

  // в”Җв”Җ delete в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (action === 'delete') {
    const id = Number(args.id)
    if (!id) return JSON.stringify({ ok: false, error: 'id required' })
    const track = getMusicTrack(id)
    if (!track) return JSON.stringify({ ok: false, error: `track id=${id} not found` })
    dbDeleteMusicTrack(id)
    return JSON.stringify({ ok: true, deleted: { id, title: track.title } })
  }

  return JSON.stringify({ ok: false, error: `unknown action: ${action}` })
}
